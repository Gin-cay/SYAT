{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "lib": ["ES2018"],
    "types": [],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "."
