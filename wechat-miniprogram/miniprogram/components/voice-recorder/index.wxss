.voice-wrap {
  margin-top: 12rpx;
}

.voice-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.mic-btn {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #165dff, #3b8cff);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(22, 93, 255, 0.35);
  flex-shrink: 0;
}

.mic-btn.mic-on {
  background: linear-gradient(145deg, #e04949, #ff7a7a);
  box-shadow: 0 8rpx 20rpx rgba(224, 73, 73, 0.35);
  animation: pulse 1.1s ease-in-out infinite;
}

@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.mic-hover {
  opacity: 0.88;
}

.mic-icon {
  font-size: 36rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
}

.voice-side {
  flex: 1;
  min-width: 0;
}

.voice-hint {
  font-size: 28rpx;
  color: #165dff;
  font-weight: 500;
}

.voice-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #86909c;
  line-height: 1.4;
}

.rec-timer {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #e04949;
  font-weight: 600;
}

.voice-result {
  margin-top: 18rpx;
  padding: 18rpx;
  background: #f0f6ff;
  border: 1rpx solid rgba(22, 93, 255, 0.2);
  border-radius: 14rpx;
}

.dur-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dur-label {
  font-size: 24rpx;
  color: #86909c;
}

.dur-val {
  font-size: 30rpx;
  color: #165dff;
  font-weight: 600;
}

.btn-row {
  margin-top: 14rpx;
  display: flex;
  gap: 16rpx;
}

.play-btn {
  background: #165dff !important;
  color: #fff !important;
  border: none !important;
  border-radius: 999rpx !important;
}

.redo-btn {
  background: #e8f0ff !important;
  color: #165dff !important;
  border: 1rpx solid #8fb4ff !important;
  border-radius: 999rpx !important;
}
