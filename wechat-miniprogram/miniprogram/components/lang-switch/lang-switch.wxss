.lang-switch {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1677ff 0%, #36bffa 100%);
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(22, 119, 255, 0.35);
}

.lang-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.02em;
}
