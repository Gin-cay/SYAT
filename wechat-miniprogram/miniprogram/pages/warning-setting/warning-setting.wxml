<view class="page">
  <view class="sync-hint" wx:if="{{syncing}}">{{i18n.wsSyncing}}</view>

  <!-- 总开关 -->
  <view class="card">
    <view class="card-head">
      <text class="card-title">{{i18n.wsMaster}}</text>
      <switch
        checked="{{settings.masterEnabled}}"
        color="#165DFF"
        bindchange="onMasterChange"
      />
    </view>
    <text class="card-desc">{{i18n.wsMasterDesc}}</text>
  </view>

  <!-- 分类 -->
  <view class="card">
    <view class="section-title">{{i18n.wsCategory}}</view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsFireRisk}}</text>
      <switch
        checked="{{settings.categories.fireRiskLevels}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        data-key="fireRiskLevels"
        bindchange="onCategoryChange"
      />
    </view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsLightning}}</text>
      <switch
        checked="{{settings.categories.lightningDrought}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        data-key="lightningDrought"
        bindchange="onCategoryChange"
      />
    </view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsFireReport}}</text>
      <switch
        checked="{{settings.categories.fireReportNotify}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        data-key="fireReportNotify"
        bindchange="onCategoryChange"
      />
    </view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsPatrol}}</text>
      <switch
        checked="{{settings.categories.patrolReminder}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        data-key="patrolReminder"
        bindchange="onCategoryChange"
      />
    </view>
  </view>

  <!-- 渠道 -->
  <view class="card">
    <view class="section-title">{{i18n.wsChannel}}</view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsWxService}}</text>
      <switch
        checked="{{settings.channels.serviceTemplate}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        data-key="serviceTemplate"
        bindchange="onChannelChange"
      />
    </view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsInApp}}</text>
      <switch
        checked="{{settings.channels.inApp}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        data-key="inApp"
        bindchange="onChannelChange"
      />
    </view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsSms}}</text>
      <switch
        checked="{{settings.channels.sms}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        data-key="sms"
        bindchange="onChannelChange"
      />
    </view>
  </view>

  <!-- 免打扰 -->
  <view class="card">
    <view class="section-title">{{i18n.wsDnd}}</view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsDndEnable}}</text>
      <switch
        checked="{{settings.dnd.enabled}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        bindchange="onDndEnabledChange"
      />
    </view>
    <view class="cell-row picker-row" wx:if="{{settings.dnd.enabled}}">
      <text class="cell-label">{{i18n.wsDndStart}}</text>
      <picker mode="time" value="{{settings.dnd.start}}" disabled="{{formDisabled}}" bindchange="onDndStartChange">
        <view class="picker-value">{{settings.dnd.start}}</view>
      </picker>
    </view>
    <view class="cell-row picker-row" wx:if="{{settings.dnd.enabled}}">
      <text class="cell-label">{{i18n.wsDndEnd}}</text>
      <picker mode="time" value="{{settings.dnd.end}}" disabled="{{formDisabled}}" bindchange="onDndEndChange">
        <view class="picker-value">{{settings.dnd.end}}</view>
      </picker>
    </view>
  </view>

  <!-- 区域 -->
  <view class="card">
    <view class="section-title">{{i18n.wsRegion}}</view>
    <view class="cell-row picker-row">
      <text class="cell-label">{{i18n.wsForest}}</text>
      <picker
        mode="selector"
        range="{{forestNames}}"
        value="{{settings.region.forestIndex}}"
        disabled="{{formDisabled}}"
        bindchange="onForestChange"
      >
        <view class="picker-value">{{forestNames[settings.region.forestIndex]}}</view>
      </picker>
    </view>
    <view class="cell-row picker-row">
      <text class="cell-label">{{i18n.wsGrid}}</text>
      <picker
        mode="selector"
        range="{{grids}}"
        value="{{settings.region.gridIndex}}"
        disabled="{{formDisabled}}"
        bindchange="onGridChange"
      >
        <view class="picker-value">{{grids[settings.region.gridIndex]}}</view>
      </picker>
    </view>
    <view class="slider-block">
      <view class="slider-label">{{radiusLabel}}</view>
      <slider
        min="1"
        max="50"
        step="1"
        show-value
        value="{{settings.region.radiusKm}}"
        disabled="{{formDisabled}}"
        activeColor="#165DFF"
        backgroundColor="#dbe7ff"
        block-color="#165DFF"
        bindchange="onRadiusChange"
      />
    </view>
  </view>

  <!-- 内容 -->
  <view class="card">
    <view class="section-title">{{i18n.wsContent}}</view>
    <view class="cell-row picker-row">
      <text class="cell-label">{{i18n.wsTemplate}}</text>
      <picker
        mode="selector"
        range="{{templateLabels}}"
        value="{{templateIndex}}"
        disabled="{{formDisabled}}"
        bindchange="onTemplateChange"
      >
        <view class="picker-value">{{templateLabels[templateIndex]}}</view>
      </picker>
    </view>
    <view class="cell-row">
      <text class="cell-label">{{i18n.wsVoice}}</text>
      <switch
        checked="{{settings.content.voiceBroadcast}}"
        disabled="{{formDisabled}}"
        color="#165DFF"
        bindchange="onVoiceChange"
      />
    </view>
  </view>

  <!-- 最近 7 天记录 -->
  <view class="card log-card">
    <view class="section-title">{{i18n.wsLogTitle}}</view>
    <view class="log-empty" wx:if="{{!logs.length}}">{{i18n.wsLogEmpty}}</view>
    <view class="log-item" wx:for="{{logs}}" wx:key="id">
      <view class="log-time">{{item.time}}</view>
      <view class="log-title">{{item.title}}</view>
      <view class="log-summary">{{item.summary}}</view>
      <view class="log-level" wx:if="{{item.level}}">{{item.level}}</view>
    </view>
  </view>
</view>
