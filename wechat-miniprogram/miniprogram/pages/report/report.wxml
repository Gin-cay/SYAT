<view class="page">
  <view class="tip" wx:if="{{loading}}">加载中…</view>

  <view class="empty" wx:if="{{!loading && empty}}">
    <text class="empty-title">暂无火情上报记录</text>
    <text class="empty-desc">在首页点击「火情上报」提交后，将在此按时间倒序展示，并显示处理状态。</text>
  </view>

  <view class="list" wx:if="{{!empty}}">
    <view class="card" wx:for="{{list}}" wx:key="id">
      <view class="card-head">
        <text class="time">{{item.reportTime}}</text>
        <view class="badges">
          <text class="badge status-{{item.processStatus}}">{{item.statusLabel}}</text>
          <text class="badge pending" wx:if="{{item.pendingSync}}">待同步</text>
        </view>
      </view>
      <view class="row">
        <text class="label">上报人</text>
        <text class="value">{{item.reporterName}}</text>
      </view>
      <view class="row">
        <text class="label">位置</text>
        <text class="value">{{item.location}}</text>
      </view>
      <view class="row">
        <text class="label">坐标</text>
        <text
          class="value link"
          data-lat="{{item.latitude}}"
          data-lng="{{item.longitude}}"
          data-place="{{item.location}}"
          bindtap="openMap"
        >{{item.coordText}} · 地图</text>
      </view>
    </view>
  </view>
</view>
