<view class="page">
  <view class="tip" wx:if="{{loading}}">{{i18n.reportListLoading}}</view>

  <view class="empty" wx:if="{{!loading && empty}}">
    <text class="empty-title">{{i18n.reportListEmpty}}</text>
    <text class="empty-desc">{{i18n.reportListEmptyDesc}}</text>
  </view>

  <view class="list" wx:if="{{!empty}}">
    <view class="card" wx:for="{{list}}" wx:key="id">
      <view class="card-head">
        <text class="time">{{item.reportTime}}</text>
        <view class="badges">
          <text class="badge status-{{item.processStatus}}">{{item.statusLabel}}</text>
          <text class="badge pending" wx:if="{{item.pendingSync}}">{{i18n.reportPendingSync}}</text>
        </view>
      </view>
      <view class="row">
        <text class="label">{{i18n.reportPerson}}</text>
        <text class="value">{{item.reporterName}}</text>
      </view>
      <view class="row">
        <text class="label">{{i18n.reportPlace}}</text>
        <text class="value">{{item.location}}</text>
      </view>
      <view class="row">
        <text class="label">{{i18n.reportCoordLabel}}</text>
        <text
          class="value link"
          data-lat="{{item.latitude}}"
          data-lng="{{item.longitude}}"
          data-place="{{item.location}}"
          bindtap="openMap"
        >{{item.coordText}} · {{i18n.reportOpenMap}}</text>
      </view>
    </view>
  </view>
</view>
