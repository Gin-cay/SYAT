<view class="page">
  <view class="card">
    <view class="title">{{i18n.reportTitle}}</view>

    <view class="field">
      <view class="label">{{i18n.reportTime}}</view>
      <input class="input disabled" value="{{form.reportTime}}" disabled />
    </view>

    <view class="field">
      <view class="label">{{i18n.reportReporter}}</view>
      <view class="reporter-row">
        <text class="reporter-name">{{form.reporterName}}</text>
        <text class="reporter-phone" wx:if="{{form.reporterPhone}}">{{form.reporterPhone}}</text>
      </view>
    </view>

    <view class="field">
      <view class="label">{{i18n.reportLocationMap}}</view>
      <view class="map-wrap" wx:if="{{hasLocation}}">
        <map
          class="map"
          latitude="{{latNum}}"
          longitude="{{lngNum}}"
          scale="{{mapScale}}"
          markers="{{markers}}"
          show-location
        />
      </view>
      <view class="map-placeholder" wx:else>{{i18n.reportMapPlaceholder}}</view>

      <view class="location-row">
        <input
          class="input location-input"
          placeholder="{{i18n.reportLocationPh}}"
          value="{{form.location}}"
          bindinput="onLocationInput"
        />
        <button class="map-btn" bindtap="onRefreshLocation">{{i18n.reportRefreshLoc}}</button>
      </view>
      <button class="map-btn map-btn-secondary" bindtap="onChooseLocationManual">{{i18n.reportMapAdjust}}</button>
      <view class="location-tip" wx:if="{{form.latitude && form.longitude}}">
        {{i18n.reportCoord}}：{{form.latitude}}, {{form.longitude}}
      </view>
    </view>

    <view class="field">
      <view class="label">{{i18n.reportScenePhotos}}</view>
      <view class="image-actions">
        <button class="img-action" size="mini" bindtap="onClearAndReselectImages">{{i18n.reportClearImages}}</button>
      </view>
      <view class="image-list">
        <view class="image-item" wx:for="{{form.images}}" wx:key="*this">
          <image
            class="preview"
            src="{{item}}"
            mode="aspectFill"
            bindtap="onPreviewImage"
            data-src="{{item}}"
          />
          <view class="remove" data-index="{{index}}" bindtap="onRemoveImage">×</view>
        </view>
        <view class="upload-box" wx:if="{{form.images.length < 3}}" bindtap="onChooseImage">{{i18n.reportAddImg}}</view>
      </view>
    </view>

    <button class="btn" bindtap="submitReport">{{i18n.reportSubmit}}</button>
  </view>
</view>
