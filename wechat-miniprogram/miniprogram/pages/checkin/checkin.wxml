<view class="page">
  <view class="card map-card">
    <view class="card-title">{{i18n.checkinRouteTitle}}</view>

    <view class="map-wrap">
      <view wx:if="{{!showRouteMap}}" class="map-placeholder">{{i18n.checkinMapHidden}}</view>
      <view wx:if="{{showRouteMap && !hasMap}}" class="map-placeholder">{{locating ? i18n.checkinMapLoading : i18n.checkinMapHint}}</view>

      <map
        wx:if="{{showRouteMap && hasMap}}"
        class="route-map"
        latitude="{{latitude}}"
        longitude="{{longitude}}"
        scale="{{mapScale}}"
        markers="{{markers}}"
        polyline="{{polyline}}"
        show-location
      ></map>

      <view wx:if="{{showRouteMap && hasMap}}" class="map-legend">
        <view class="legend-line"></view>
        <text class="legend-text">{{i18n.checkinLegend}}</text>
      </view>
    </view>

    <view class="map-actions">
      <view class="toggle-wrap">
        <text class="toggle-label">{{i18n.checkinShowRoute}}</text>
        <switch checked="{{showRouteMap}}" color="#25b879" bindchange="onToggleRouteMap" />
      </view>

      <button class="ghost-btn" size="mini" bindtap="refreshLocation" disabled="{{locating}}">
        {{locating ? i18n.checkinLocating : i18n.checkinRelocate}}
      </button>

      <button class="ghost-btn primary-outline" size="mini" bindtap="onPickMapLocation">{{i18n.checkinMapPick}}</button>
    </view>
  </view>

  <view class="card">
    <view class="card-title">{{i18n.checkinInfoTitle}}</view>

    <view wx:if="{{highFireRiskAltitude}}" class="hint fire">{{altitudeTip}}</view>
    <view wx:if="{{locationError}}" class="hint err">{{locationError}}</view>

    <view class="field">
      <text class="label">{{i18n.checkinPlace}}</text>
      <textarea
        class="textarea place-input"
        value="{{patrolPlace}}"
        placeholder="{{i18n.checkinPlacePh}}"
        auto-height
        maxlength="200"
        bindinput="onPatrolPlaceInput"
      />
    </view>

    <view class="row">
      <text class="label">{{i18n.checkinInspector}}</text>
      <text class="value">{{inspectorName}}</text>
    </view>

    <view class="row">
      <text class="label">{{i18n.checkinTime}}</text>
      <text class="value">{{checkTime}}</text>
    </view>

    <view class="field">
      <text class="label">{{i18n.checkinSituation}}</text>
      <radio-group class="radio-group" bindchange="onPatrolStatusChange">
        <label class="radio-item">
          <radio value="normal" checked="{{patrolStatus === 'normal'}}" color="#1677FF" />
          <text>{{i18n.checkinNormal}}</text>
        </label>
        <label class="radio-item">
          <radio value="hazard" checked="{{patrolStatus === 'hazard'}}" color="#1677FF" />
          <text>{{i18n.checkinHazard}}</text>
        </label>
      </radio-group>
    </view>

    <block wx:if="{{patrolStatus === 'hazard'}}">
      <view class="field">
        <text class="label">{{i18n.checkinHazardDesc}}</text>
        <textarea
          class="textarea"
          value="{{hazardDesc}}"
          placeholder="{{i18n.checkinHazardPh}}"
          maxlength="500"
          bindinput="onHazardDescInput"
        />
      </view>

      <view class="field">
        <text class="label">{{i18n.checkinHazardImg}}</text>
        <view class="img-grid">
          <view
            class="img-thumb"
            wx:for="{{hazardImages}}"
            wx:key="*this"
            data-index="{{index}}"
            bindtap="previewHazardImage"
          >
            <image class="img" src="{{item}}" mode="aspectFill" />
            <view class="img-del" data-index="{{index}}" catchtap="removeHazardImage">×</view>
          </view>

          <view class="img-add" bindtap="chooseHazardImages" wx:if="{{hazardImages.length < 9}}">
            <text class="img-add-plus">+</text>
            <text class="img-add-text">{{i18n.checkinUploadImg}}</text>
          </view>
        </view>
      </view>
    </block>

    <button class="btn" bindtap="submitCheckin" loading="{{submitting}}" disabled="{{submitting}}">
      {{i18n.checkinSubmit}}
    </button>
  </view>
</view>
