.page {
  min-height: 100vh;
  background: #f2f7ff;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid #dbe7ff;
  border-radius: 16rpx;
  padding: 26rpx;
  box-shadow: 0 10rpx 28rpx rgba(22, 93, 255, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #165DFF;
  display: block;
}

.desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6b7f96;
  line-height: 1.6;
  display: block;
}

.login-btn {
  margin-top: 28rpx;
  border: none;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #165DFF 0%, #00B42A 100%);
  color: #ffffff;
  font-size: 30rpx;
}
