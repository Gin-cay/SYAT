<view class="container">
  <view class="status-card {{riskCardClass}}" bindtap="goWarning">
    <view class="status-header">
      <view class="status-title">事前火险研判</view>
      <view class="status-chip">{{riskChipText}}</view>
    </view>
    <view class="status-desc">{{statusDesc}}</view>
    <view class="status-go">进入预警中心 · 热力图与气象 ›</view>
  </view>

  <view class="data-grid">
    <view class="data-item">
      <view class="data-label">今日火险等级</view>
      <view class="data-value">{{todayData.riskLevel}}</view>
    </view>
    <view class="data-item">
      <view class="data-label">温度</view>
      <view class="data-value">
        {{todayData.temperature}}
        <text class="unit">°C</text>
      </view>
    </view>
    <view class="data-item">
      <view class="data-label">湿度</view>
      <view class="data-value">
        {{todayData.humidity}}
        <text class="unit">%</text>
      </view>
    </view>
    <view class="data-item">
      <view class="data-label">风力</view>
      <view class="data-value">
        {{todayData.wind}}
        <text class="unit">级</text>
      </view>
    </view>
  </view>

  <view class="action-group">
    <button class="action-btn patrol-btn" bindtap="onPatrolCheckin">防火巡查打卡</button>
    <button class="action-btn report-btn" bindtap="onFireReport">火情上报</button>
  </view>

  <view class="history-card">
    <view class="history-title">历史预警记录</view>
    <view class="history-item" wx:for="{{historyList}}" wx:key="id">
      <view class="history-time">{{item.time}}</view>
      <view class="history-area">{{item.area}}</view>
      <view class="history-level">{{item.level}}</view>
    </view>
  </view>

  <!-- 上报记录（离线会先缓存，联网后自动上传） -->
  <view class="emergency-records" wx:if="{{emergencyRecords.length}}">
    <view class="history-title emergency-title">上报记录</view>
    <view class="emergency-item" wx:for="{{emergencyRecords}}" wx:key="id">
      <view class="emergency-time">{{item.timeText}}</view>
      <view class="emergency-status">{{item.statusText}}</view>
    </view>
  </view>

  <!-- 底部中间：紧急上报按钮 -->
  <button class="emergency-btn" bindtap="onEmergencyReport">紧急上报</button>
</view>