page {
  min-height: 100vh;
  background: #f2f7ff;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.tip-bar {
  font-size: 24rpx;
  color: #5f708a;
  margin-bottom: 16rpx;
}

.empty {
  background: #ffffff;
  border: 1rpx solid #dbe7ff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #124b97;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #5f708a;
  line-height: 1.6;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #dbe7ff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.time {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2d3d;
}

.badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.badge.ok {
  background: rgba(31, 167, 94, 0.12);
  color: #1fa75e;
}

.badge.bad {
  background: rgba(224, 69, 69, 0.12);
  color: #c0392b;
}

.row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.label {
  width: 160rpx;
  color: #5f708a;
  flex-shrink: 0;
}

.value {
  flex: 1;
  color: #1f2d3d;
  word-break: break-all;
}

.value.place {
  line-height: 1.5;
}

.value.link {
  color: #165dff;
  text-decoration: underline;
}

.hazard {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #fff7f5;
  border-radius: 12rpx;
  border: 1rpx solid #ffd8cf;
}

.hazard-label {
  display: block;
  font-size: 22rpx;
  color: #c0392b;
  margin-bottom: 8rpx;
}

.hazard-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}
