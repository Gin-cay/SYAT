<view class="page">
  <view class="tip-bar" wx:if="{{loading}}">正在同步记录…</view>

  <view class="empty" wx:if="{{!loading && empty}}">
    <text class="empty-title">暂无巡查记录</text>
    <text class="empty-desc">在首页点击「防火巡查打卡」完成首次打卡后，将在此展示历史记录。</text>
  </view>

  <view class="list" wx:if="{{!empty}}">
    <view class="card" wx:for="{{list}}" wx:key="id">
      <view class="card-head">
        <text class="time">{{item.time}}</text>
        <text class="badge {{item.status === 'hazard' ? 'bad' : 'ok'}}">{{item.statusLabel}}</text>
      </view>
      <view class="row">
        <text class="label">巡查人员</text>
        <text class="value">{{item.inspector}}</text>
      </view>
      <view class="row">
        <text class="label">巡查地点</text>
        <text class="value place">{{item.place}}</text>
      </view>
      <view class="row">
        <text class="label">定位坐标</text>
        <text
          class="value link"
          data-lat="{{item.latitude}}"
          data-lng="{{item.longitude}}"
          data-place="{{item.place}}"
          bindtap="openMap"
        >{{item.coordText}} · 打开地图</text>
      </view>
      <view class="row" wx:if="{{item.patrolDurationMin}}">
        <text class="label">巡查时长</text>
        <text class="value">约 {{item.patrolDurationMin}} 分钟</text>
      </view>
      <view class="hazard" wx:if="{{item.status === 'hazard' && item.hazardDesc}}">
        <text class="hazard-label">隐患说明</text>
        <text class="hazard-text">{{item.hazardDesc}}</text>
      </view>
    </view>
  </view>
</view>
