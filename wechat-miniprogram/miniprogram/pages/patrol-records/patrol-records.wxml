<view class="page">
  <view class="tip-bar" wx:if="{{loading}}">{{i18n.patrolSyncing}}</view>

  <view class="empty" wx:if="{{!loading && empty}}">
    <text class="empty-title">{{i18n.patrolEmptyTitle}}</text>
    <text class="empty-desc">{{i18n.patrolEmptyDesc}}</text>
  </view>

  <view class="list" wx:if="{{!empty}}">
    <view class="card" wx:for="{{list}}" wx:key="id">
      <view class="card-head">
        <text class="time">{{item.time}}</text>
        <text class="badge {{item.status === 'hazard' ? 'bad' : 'ok'}}">{{item.statusLabel}}</text>
      </view>
      <view class="row">
        <text class="label">{{i18n.patrolInspector}}</text>
        <text class="value">{{item.inspector}}</text>
      </view>
      <view class="row">
        <text class="label">{{i18n.patrolPlace}}</text>
        <text class="value place">{{item.place}}</text>
      </view>
      <view class="row">
        <text class="label">{{i18n.patrolCoord}}</text>
        <text
          class="value link"
          data-lat="{{item.latitude}}"
          data-lng="{{item.longitude}}"
          data-place="{{item.place}}"
          bindtap="openMap"
        >{{item.coordText}} · {{i18n.patrolOpenMap}}</text>
      </view>
      <view class="row" wx:if="{{item.patrolDurationMin}}">
        <text class="label">{{i18n.patrolDuration}}</text>
        <text class="value">{{i18n.patrolAboutMin}} {{item.patrolDurationMin}} {{i18n.minute}}</text>
      </view>
      <view class="hazard" wx:if="{{item.status === 'hazard' && item.hazardDesc}}">
        <text class="hazard-label">{{i18n.patrolHazardNote}}</text>
        <text class="hazard-text">{{item.hazardDesc}}</text>
      </view>
    </view>
  </view>
</view>
